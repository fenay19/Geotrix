# GeoTrade Backend Environment Variables Template
# Copy this file to `.env` and fill in your actual values.

# ── Core Project Settings ────────────────────────────────────────────────────
PROJECT_NAME="geotrade-ai-platform"
API_V1_STR="/api/v1"
DEBUG=True

# ── Database Configuration ───────────────────────────────────────────────────
# Points to local SQLite database (sql_app.db) in the backend directory
DATABASE_URL="sqlite:///./sql_app.db"

# ── JWT Authentication / Security ────────────────────────────────────────────
# Secure random key generated for JWT token signing (e.g. `openssl rand -hex 32`).
SECRET_KEY="placeholder_secret_key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Guest Analyst Credentials ────────────────────────────────────────────────
GUEST_ANALYST_EMAIL="analyst@geotrade.ai"
GUEST_ANALYST_PASSWORD="geotrade2026"

# ── Allowed CORS Origins ─────────────────────────────────────────────────────
# JSON list format of allowed web origins
ALLOWED_ORIGINS='["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]'

# ── AI / LLM Configuration ───────────────────────────────────────────────────
# OpenAI API Key is required for RAG reasoning, NLP categorization, and forecast scenario generation.
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_API_BASE_URL="https://api.openai.com/v1"
DEFAULT_AI_MODEL="gpt-4o-mini"
DEFAULT_EMBEDDING_MODEL="text-embedding-3-small"

# ── Geopolitical News & Market Data API Keys ─────────────────────────────────
# Required for live market quotes and market indicators
FINNHUB_API_KEY="your_finnhub_api_key_here"

# Required for geopolitical news ingestion pipelines
NEWS_API_KEY="your_news_api_key_here"

# Optional: Hugging Face API Key (if accessing private models)
HUGGINGFACE_API_KEY="your_huggingface_api_key_here"

# ── Machine Learning & Quant Engine Configuration ────────────────────────────
ML_CONFIDENCE_THRESHOLD=0.45
ML_MODELS_DIR="app/ml/saved_models"
YFINANCE_ENABLED=True
MONTE_CARLO_N_SIMS=10000

# ── Background Sync Scheduler Configuration ──────────────────────────────────
SCHEDULER_ENABLED=True
# Interval in seconds at which the background sync runs (3600s = 1 hour)
SCHEDULER_INTERVAL_SECONDS=3600

# Optional: Local HuggingFace cache directory (uncomment to redirect HF model downloads)
# HF_HOME="app/ml/hf_cache"
